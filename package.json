{
  "name": "eduma",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "a": "react-native run-android",
    "ios": "npx react-native run-ios",
    "ip15promax": "npx react-native run-ios --simulator='iPhone 15 Pro Max'",
    "ip16promax": "npx react-native run-ios --simulator='iPhone 16 Pro Max'",
    "ipad": "npx react-native run-ios --simulator='iPad (8th generation)'",
    "ipadpro": "npx react-native run-ios --simulator='iPad Pro (6th generation)'",
    "pod": "cd ios && pod install && cd ..",
    "iX": "react-native run-ios --simulator=\"iPhone X\"",
    "i8": "react-native run-ios --simulator=\"iPhone 8\"",
    "dip": "react-native run-ios --device",
    "clean-a": "cd android && ./gradlew clean && cd ..",
    "bundle-a": "cd android && ./gradlew bundleRelease && cd ..",
    "build-a": "cd android && ./gradlew assembleRelease && cd ..",
    "postinstall": "patch-package"
  },
  "dependencies": {
